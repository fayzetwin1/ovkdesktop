<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ovkdesktop.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ovkdesktop"
    xmlns:models="using:ovkdesktop.Models"
    xmlns:converters="using:ovkdesktop.Converters"
    xmlns:controls="using:ovkdesktop.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToMediaPlaybackSourceConverter x:Key="StringToMediaPlaybackSourceConverter"/>
        <converters:IntToColorConverter x:Key="LikeButtonColorConverter"/>
        <converters:ProfileToImageConverter x:Key="ProfileToImageConverter"/>
        
        <DataTemplate x:Key="RepostItemTemplate" x:DataType="models:UserWallPost">
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4"
                Padding="10" Margin="0,5,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{x:Bind AuthorProfile, Mode=OneWay, Converter={StaticResource ProfileToImageConverter}}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Background="Transparent" BorderThickness="0" Padding="0,2" Margin="0" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Tag="{x:Bind FromId}" Click="RepostAuthor_Click">
                                <TextBlock Text="{x:Bind AuthorProfile.FullName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </Button>
                            <TextBlock Text="{x:Bind FormattedDate, Mode=OneWay}" Opacity="0.7" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{x:Bind Text, Mode=OneWay}" TextWrapping="Wrap" Margin="0,0,0,10" Visibility="{x:Bind Text, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                    
                    <controls:PostMediaControl Attachments="{x:Bind Attachments, Mode=OneWay}" />

                    <ItemsControl ItemsSource="{x:Bind CopyHistory, Mode=OneWay}" 
                                  ItemTemplate="{StaticResource RepostItemTemplate}" 
                                  Visibility="{x:Bind HasRepost, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- User profile (avatar and information) -->
        <Grid Grid.Row="0" Margin="125,105,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- User avatar -->
            <PersonPicture Grid.Column="0" 
                          x:Name="ProfileAvatar" 
                          ProfilePicture="{x:Bind ViewModel.CurrentUserProfile, Mode=OneWay, Converter={StaticResource ProfileToImageConverter}}"
                          Width="120" Height="120"
                          VerticalAlignment="Top"/>

            <!-- User information -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock x:Name="ProfileName" 
                          Text="{x:Bind ViewModel.CurrentUserProfile.FullName, Mode=OneWay, FallbackValue='Загрузка...'}" 
                          Style="{ThemeResource TitleLargeTextBlockStyle}" 
                          FontSize="32"/>

                <TextBlock x:Name="PostsCountText" 
                          Text="{x:Bind ViewModel.PostsCountText, Mode=OneWay, FallbackValue='Загрузка постов...'}" 
                          Opacity="0.7" 
                          Style="{ThemeResource BodyTextBlockStyle}"
                          Margin="0,5,0,15"/>

                <TextBlock x:Name="ErrorTextBlock" 
                          Foreground="Red" 
                          Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" 
                          Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                          TextWrapping="Wrap"
                          Margin="0,0,0,10"/>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Опубликовать пост" Click="PublishNewPostButton"/>
                    <Button Content="Отредактировать профиль"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Posts list -->
        <Grid Grid.Row="1" Margin="110,20,20,20" x:Name="GridPostsMyProfile">
            <ProgressRing x:Name="LoadingProgressRing" 
                         IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                         Width="50" Height="50" 
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center"/>

            <ListView x:Name="PostsListView" 
                     ItemsSource="{x:Bind ViewModel.Posts, Mode=OneWay}"
                     HorizontalAlignment="Stretch">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UserWallPost">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1" CornerRadius="8"
                               Margin="0,5,0,10" Padding="15"
                               HorizontalAlignment="Stretch">

                            <Border.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Репост" 
                                        Click="RepostItem_Click"/>
                                </MenuFlyout>
                            </Border.ContextFlyout>

                            <Grid HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Post Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Author Avatar -->
                                    <Button Grid.Column="0" Padding="0" BorderThickness="0" Background="Transparent"
                                        Tag="{x:Bind FromId}" Click="Author_Click"
                                        VerticalAlignment="Top">
                                        <Ellipse Width="48" Height="48" Margin="0,0,12,0">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{x:Bind AuthorProfile, Mode=OneWay, Converter={StaticResource ProfileToImageConverter}}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Button>

                                    <!-- Author Info & Date -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                                            <Button Padding="0" Margin="0,-2,0,0" BorderThickness="0" Background="Transparent"
                                                Tag="{x:Bind FromId}" Click="Author_Click">
                                                <TextBlock Text="{x:Bind AuthorProfile.FullName, Mode=OneWay}" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            </Button>

                                            <StackPanel Orientation="Horizontal" Spacing="5"
                                                Visibility="{x:Bind IsWallPostByAnotherUser, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text=">" FontWeight="SemiBold" Opacity="0.7"/>
                                                <TextBlock Text="{Binding ElementName=ProfileName, Path=Text}" FontWeight="SemiBold" Opacity="0.7"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Date and Pinned Icon -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                            <TextBlock Text="{x:Bind FormattedDate, Mode=OneWay}" Opacity="0.7" FontSize="12"/>
                                            <FontIcon Glyph="&#xE840;" FontSize="12"
                                                  Foreground="{ThemeResource SystemAccentColor}"
                                                  ToolTipService.ToolTip="Закрепленная запись"
                                                  Visibility="{x:Bind IsPinned, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Post text -->
                                <TextBlock Grid.Row="1"
                                          Text="{x:Bind Text, Mode=OneWay}"
                                          TextWrapping="Wrap" Margin="0,0,0,10"
                                          Foreground="{ThemeResource TextFillColorPrimary}"/>

                                <!-- Media Attachments -->
                                <controls:PostMediaControl Grid.Row="2" Attachments="{x:Bind Attachments, Mode=OneWay}" />

                                <!-- Repost -->
                                <ItemsControl Grid.Row="3"
                                      ItemsSource="{x:Bind CopyHistory, Mode=OneWay}"
                                      Visibility="{x:Bind HasRepost, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                      ItemTemplate="{StaticResource RepostItemTemplate}"
                                      Margin="0,0,0,10"/>

                                <!-- Likes and comments -->
                                <StackPanel Grid.Row="4" 
                                          Orientation="Horizontal" 
                                          Spacing="15" 
                                          Margin="0,20,0,0"
                                          VerticalAlignment="Bottom">
                                    <!-- Like button -->
                                    <Button Tag="{Binding}" 
                                            Click="LikeButton_Click" 
                                            Background="Transparent" 
                                            BorderThickness="0" 
                                            Padding="5,2">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="❤" />
                                            <TextBlock Text="{x:Bind Likes.Count, Mode=OneWay, FallbackValue='0'}" 
                                                       Foreground="{x:Bind Likes.UserLikes, Mode=OneWay, Converter={StaticResource LikeButtonColorConverter}, FallbackValue=Black}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Comments button -->
                                    <Button Tag="{Binding}" 
                                            Tapped="ShowPostComments_Tapped" 
                                            Background="Transparent" 
                                            BorderThickness="0" 
                                            Padding="5,2">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="💬" />
                                            <TextBlock Text="{x:Bind Comments.Count, Mode=OneWay, FallbackValue='0'}" 
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Navigation frame -->
        <Frame x:Name="ContentProfileFrame" Grid.RowSpan="2">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition />
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</Page>