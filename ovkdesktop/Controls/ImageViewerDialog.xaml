<UserControl
    x:Class="ovkdesktop.Controls.ImageViewerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    
    <Grid Background="#E6000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <ScrollViewer ZoomMode="Enabled" MinZoomFactor="0.5" MaxZoomFactor="4.0" 
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Image x:Name="PreviewImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"/>
        </ScrollViewer>
        
        <!-- Top padding of 50px ensures buttons are positioned below the standard title bar (where Minimize/Maximize/Close system buttons are located) -->
        <Grid VerticalAlignment="Top" Padding="20,45,20,20">
            <Button Content="Закрыть" Click="CloseButton_Click" HorizontalAlignment="Left" Style="{ThemeResource AccentButtonStyle}"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Копировать" Click="CopyButton_Click"/>
                <Button Content="Скачать" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
        
        <ProgressRing x:Name="LoadingRing" IsActive="True" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
