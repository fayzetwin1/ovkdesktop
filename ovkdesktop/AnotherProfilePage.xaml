<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ovkdesktop.AnotherProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ovkdesktop"
    xmlns:models="using:ovkdesktop.Models"
    xmlns:converters="using:ovkdesktop.Converters"
    xmlns:controls="using:ovkdesktop.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToMediaPlaybackSourceConverter x:Key="StringToMediaPlaybackSourceConverter"/>
        <converters:IntToColorConverter x:Key="LikeButtonColorConverter"/>
        <converters:ProfileToImageConverter x:Key="ProfileToImageConverter"/>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
        
        <DataTemplate x:Key="RepostItemTemplateLevel2" x:DataType="models:UserWallPost">
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4"
                Padding="10" Margin="0,5,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding AuthorProfile, Converter={StaticResource ProfileToImageConverter}}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Background="Transparent" BorderThickness="0" Padding="0,2" Margin="0" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Tag="{Binding FromId}" Click="RepostAuthor_Click">
                                <TextBlock Text="{Binding AuthorProfile.FullName}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </Button>
                            <TextBlock Text="{Binding FormattedDate}" Opacity="0.7" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,0,0,10" Visibility="{Binding Text, Converter={StaticResource StringToVisibilityConverter}}"/>
                    <Image Source="{Binding MainImageUrl}" Stretch="Uniform" MaxHeight="300" HorizontalAlignment="Left" Margin="0,0,0,10" Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Image Source="{Binding GifUrl}" Stretch="Uniform" MaxHeight="300" HorizontalAlignment="Left" Margin="0,0,0,10" Visibility="{Binding HasGif, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Grid Visibility="{Binding HasVideo, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,0" HorizontalAlignment="Left">
                        <MediaPlayerElement Source="{Binding MainVideo.Player, Converter={StaticResource StringToMediaPlaybackSourceConverter}}" MaxHeight="300" AreTransportControlsEnabled="True"/>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
        <converters:AttachmentTemplateSelector x:Key="AttachmentTemplateSelector">
            <converters:AttachmentTemplateSelector.PhotoTemplate>
                <DataTemplate x:DataType="models:Attachment">
                    <Image Source="{Binding Photo.BestQualityUrl}"
                   Stretch="Uniform" MaxHeight="400"
                   HorizontalAlignment="Left" Margin="0,0,0,10"/>
                </DataTemplate>
            </converters:AttachmentTemplateSelector.PhotoTemplate>

            <!-- video -->
            <converters:AttachmentTemplateSelector.VideoTemplate>
                <DataTemplate x:DataType="models:Attachment">
                    <MediaPlayerElement 
                Source="{Binding Video.Player, Converter={StaticResource StringToMediaPlaybackSourceConverter}}"
                MaxHeight="400" AreTransportControlsEnabled="True"
                HorizontalAlignment="Left" Margin="0,0,0,10"/>
                </DataTemplate>
            </converters:AttachmentTemplateSelector.VideoTemplate>

            <!-- gif (doc) -->
            <converters:AttachmentTemplateSelector.GifTemplate>
                <DataTemplate x:DataType="models:Attachment">
                    <Image Source="{Binding Doc.Url}"
                   Stretch="Uniform" MaxHeight="400"
                   HorizontalAlignment="Left" Margin="0,0,0,10"/>
                </DataTemplate>
            </converters:AttachmentTemplateSelector.GifTemplate>

            <!-- unknown types -->
            <converters:AttachmentTemplateSelector.OtherTemplate>
                <DataTemplate x:DataType="models:Attachment">
                    <TextBlock Text="{Binding Type, FallbackValue='Вложение'}" 
                       FontWeight="SemiBold" Margin="0,5"/>
                </DataTemplate>
            </converters:AttachmentTemplateSelector.OtherTemplate>

        </converters:AttachmentTemplateSelector>

        <DataTemplate x:Key="RepostItemTemplate" x:DataType="models:UserWallPost">
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4"
                Padding="10" Margin="0,5,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding AuthorProfile, Converter={StaticResource ProfileToImageConverter}}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Background="Transparent" BorderThickness="0" Padding="0,2" Margin="0" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Tag="{Binding FromId}" Click="RepostAuthor_Click">
                                <TextBlock Text="{Binding AuthorProfile.FullName}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </Button>
                            <TextBlock Text="{Binding FormattedDate}" Opacity="0.7" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,0,0,10" Visibility="{Binding Text, Converter={StaticResource StringToVisibilityConverter}}"/>
                    <Image Source="{Binding MainImageUrl}" Stretch="Uniform" MaxHeight="300" HorizontalAlignment="Left" Margin="0,0,0,10" Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Image Source="{Binding GifUrl}" Stretch="Uniform" MaxHeight="300" HorizontalAlignment="Left" Margin="0,0,0,10" Visibility="{Binding HasGif, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Grid Visibility="{Binding HasVideo, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,0" HorizontalAlignment="Left">
                        <MediaPlayerElement Source="{Binding MainVideo.Player, Converter={StaticResource StringToMediaPlaybackSourceConverter}}" MaxHeight="300" AreTransportControlsEnabled="True"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding CopyHistory}" 
                              ItemTemplate="{StaticResource RepostItemTemplateLevel2}" 
                              Visibility="{Binding HasRepost, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,10,20,0">
            <Button Click="BackPostsClick" AutomationProperties.Name="Back" 
                   CornerRadius="5" Margin="0,0,0,0" HorizontalAlignment="Left">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <TextBlock x:Name="ErrorText" Foreground="Red" Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                      TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <ScrollViewer x:Name="PageScrollViewer" Grid.Row="1" Margin="0,10,0,0" ViewChanged="PageScrollViewer_ViewChanged">
            <StackPanel Margin="20,0,20,20">
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <PersonPicture Grid.Column="0" 
                                  x:Name="ProfileAvatar" 
                                  ProfilePicture="{x:Bind ViewModel.ProfilePhotoUrl, Mode=OneWay}"
                                  Width="150" Height="150" Margin="50,25,20,0" VerticalAlignment="Top"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ProfileNameTextBlock" Text="{x:Bind ViewModel.ProfileName, Mode=OneWay, FallbackValue='Загрузка...'}" 
                                  Style="{ThemeResource TitleLargeTextBlockStyle}" FontSize="42" Margin="10,20,20,0"/>
                        
                        <StackPanel x:Name="FriendActionsPanel" Orientation="Horizontal" Margin="10,10,0,10" Visibility="{x:Bind ViewModel.IsUser, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button x:Name="AddFriendButton" Command="{x:Bind ViewModel.ToggleFriendshipCommand}" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <FontIcon Glyph="&#xE8FA;" FontSize="16"/>
                                    <TextBlock Text="Добавить в друзья"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="GroupActionsPanel" Orientation="Horizontal" Margin="10,10,0,10" Visibility="{x:Bind ViewModel.IsGroup, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="10">
                            <Button x:Name="JoinLeaveGroupButton" Command="{x:Bind ViewModel.ToggleGroupMembershipCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <FontIcon x:Name="JoinLeaveIcon" Glyph="&#xE710;"/>
                                    <TextBlock x:Name="JoinLeaveText" Text="Подписаться"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{x:Bind ViewModel.PostsCountText, Mode=OneWay, FallbackValue='Загрузка записей на стене'}" Style="{ThemeResource SubtitleTextBlockStyle}" 
                          Margin="60,10,0,10"/>

                <ProgressRing x:Name="LoadingProgressRing" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                             Width="50" Height="50" 
                             HorizontalAlignment="Center" Margin="0,20,0,0"/>

                <ListView x:Name="PostsListView" 
                         ItemsSource="{x:Bind ViewModel.Posts, Mode=OneWay}"
                         HorizontalAlignment="Stretch">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0,0,0,10" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:UserWallPost">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Margin="60,0,60,0" Padding="15"
                                    HorizontalAlignment="Stretch">

                                <StackPanel>
                                    <!-- Header -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button Padding="0" Background="Transparent" BorderThickness="0" 
                                                Tag="{x:Bind FromId}"
                                                Click="Author_Click">
                                            <Ellipse Width="48" Height="48">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{x:Bind AuthorProfile.BestAvailablePhoto, Mode=OneWay}" Stretch="UniformToFill" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Button>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Button Padding="0" Background="Transparent" BorderThickness="0" 
                                                    Tag="{x:Bind FromId}"
                                                    Click="Author_Click">
                                                <TextBlock Text="{x:Bind AuthorProfile.FullName, Mode=OneWay}" FontWeight="SemiBold" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            </Button>
                                            <TextBlock Text="{x:Bind FormattedDate, Mode=OneWay}" FontSize="13" Opacity="0.7" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Post Text -->
                                    <TextBlock Text="{x:Bind Text, Mode=OneWay}" TextWrapping="Wrap" Margin="0,0,0,10" IsTextSelectionEnabled="True" Visibility="{x:Bind Text, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" />

                                    <!-- Media Attachments -->
                                    <controls:PostMediaControl Attachments="{x:Bind Attachments, Mode=OneWay}" />

                                    <!-- Repost -->
                                    <ItemsControl ItemsSource="{x:Bind CopyHistory, Mode=OneWay}" 
                                                  ItemTemplate="{StaticResource RepostItemTemplate}" 
                                                  Visibility="{x:Bind HasRepost, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  Margin="0,0,0,10"/>

                                    <!-- Likes and comments -->
                                    <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,15,0,0">
                                        <!-- Like button -->
                                        <Button Tag="{Binding}" 
                                                Click="LikeButton_Click" 
                                                Background="Transparent" 
                                                BorderThickness="0" 
                                                Padding="5,2">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="❤" />
                                                <TextBlock Text="{x:Bind Likes.Count, Mode=OneWay}" 
                                                           Foreground="{x:Bind Likes.UserLikes, Mode=OneWay, Converter={StaticResource LikeButtonColorConverter}}"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Comments button -->
                                        <Button Tag="{Binding}" 
                                                Tapped="ShowPostComments_Tapped" 
                                                Background="Transparent" 
                                                BorderThickness="0" 
                                                Padding="5,2">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="💬" />
                                                <TextBlock Text="{x:Bind Comments.Count, Mode=OneWay}" />
                                            </StackPanel>
                                        </Button>

                                        <!-- Repost button -->
                                        <Button Tag="{Binding}" 
                                                Click="RepostItem_Click" 
                                                Background="Transparent" 
                                                BorderThickness="0" 
                                                Padding="5,2">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="🔁" />
                                                <TextBlock Text="{x:Bind Reposts.Count, Mode=OneWay}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" 
                             Width="30" Height="30" 
                             HorizontalAlignment="Center" Margin="0,20,0,20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>